# 공개 사이트 루트 - /spokedu OG, canonical, sitemap, 카카오 공유 등 절대 URL 기준
# 도메인 연결 전: 비워도 Preview는 VERCEL_URL 기준으로 동작
# 도메인 연결 후 Production: 실제 서비스 URL 설정 후 Redeploy
# 아직 spokedu.com을 쓰지 않는다면 spokedu.com을 넣지 말 것
# 예: NEXT_PUBLIC_SITE_URL=https://실제도메인  (끝 슬래시 없이)
NEXT_PUBLIC_SITE_URL=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Scheduled jobs
# Vercel/Supabase cron 등 서버 간 호출에서 Authorization: Bearer <CRON_SECRET> 로 사용
CRON_SECRET=

# SPOKEDU MASTER operator alerts (sanitized summaries only)
SPOKEDU_MONITORING_WEBHOOK_URL=

# SPOKEDU MASTER disposable QA (staging smoke only)
SPOKEDU_MASTER_QA_ID=
SPOKEDU_MASTER_QA_PASSWORD=

# Optional read-only DB checks (restore rehearsal / data-integrity)
# SPOKEDU_MASTER_DATABASE_URL=

# Toss Payments (SPOKEDU MASTER 월 자동결제)
NEXT_PUBLIC_TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=

# SPOMAT 구매 리다이렉트 (미설정 시 프로필 스토어 메뉴 비노출)
SPOMAT_PUBLIC_PURCHASE_URL=
SPOMAT_PREMIUM_PURCHASE_URL=

# Kakao JavaScript SDK
# Kakao Developers > JavaScript 키
# JavaScript SDK 도메인과 제품 링크 관리 웹 도메인에 NEXT_PUBLIC_SITE_URL 호스트 등록
NEXT_PUBLIC_KAKAO_JS_KEY=
# KAKAO_JS_KEY=

# 카카오톡 채널 프로필 ID (pf.kakao.com/_XXXX 의 _XXXX)
# 비우면 스포키듀 기본 _VGWxeb
NEXT_PUBLIC_KAKAO_CHANNEL_PUBLIC_ID=

# 선택: 카카오채널 1:1 채팅 URL
# 비우면 앱 기본값(https://pf.kakao.com/_VGWxeb/chat) 사용
NEXT_PUBLIC_KAKAO_CHANNEL_CHAT_URL=
