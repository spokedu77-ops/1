# ──────────────────────────────────────────────────────────────
# Supabase
# ──────────────────────────────────────────────────────────────
# Supabase 프로젝트 URL (Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon key (공개 - 클라이언트에서 사용)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key (비밀 - 서버에서만 사용, 절대 노출 금지)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ──────────────────────────────────────────────────────────────
# 스포키듀 Pro DB 마이그레이션 플래그
# Supabase에서 supabase/migrations/20260308000000_spokedu_pro_commercial.sql 실행 후 true로 변경
# ──────────────────────────────────────────────────────────────
SPOKEDU_PRO_DB_READY=false

# ──────────────────────────────────────────────────────────────
# Stripe (결제)
# Stripe 대시보드 > Developers > API keys
# ──────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...

# Stripe 대시보드 > Products > 각 플랜의 Price ID
STRIPE_PRICE_BASIC=price_...
STRIPE_PRICE_PRO=price_...

# Stripe 대시보드 > Developers > Webhooks > 서명 시크릿
# 웹훅 엔드포인트: https://your-domain.com/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# ──────────────────────────────────────────────────────────────
# 앱 URL (Stripe 리다이렉트용)
# ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-domain.com

# ──────────────────────────────────────────────────────────────
# Google Gemini AI (AI 리포트)
# Google AI Studio (aistudio.google.com) 에서 발급
# ──────────────────────────────────────────────────────────────
GOOGLE_GEMINI_API_KEY=AIza...

# ──────────────────────────────────────────────────────────────
# CRON 작업 인증 시크릿 (선택)
# Vercel Cron 또는 외부 스케줄러에서 호출 시 Bearer 토큰으로 사용
# ──────────────────────────────────────────────────────────────
CRON_SECRET=your-random-secret
