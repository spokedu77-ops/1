# ──────────────────────────────────────────────────────────────
# Supabase
# ──────────────────────────────────────────────────────────────
# Supabase 프로젝트 URL (Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon key (공개 - 클라이언트에서 사용)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key (비밀 - 서버에서만 사용, 절대 노출 금지)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ──────────────────────────────────────────────────────────────
# 스포키듀 Pro DB 마이그레이션 플래그
# Supabase에서 supabase/migrations/20260308000000_spokedu_pro_commercial.sql 실행 후 true로 변경
# ──────────────────────────────────────────────────────────────
SPOKEDU_PRO_DB_READY=false

# ──────────────────────────────────────────────────────────────
# 포트원(PortOne) V2 — 국내 정기결제 (토스페이먼츠 등)
# 포트원 콘솔: https://console.portone.io
# ──────────────────────────────────────────────────────────────

# 서버 전용 시크릿 (절대 노출 금지)
# 포트원 콘솔 > 결제 연동 > V2 API 시크릿
PORTONE_SECRET=v2_live_...

# 웹훅 서명 검증 시크릿
# 포트원 콘솔 > 웹훅 > 서명 시크릿
# 웹훅 엔드포인트: https://your-domain.com/api/portone/webhook
PORTONE_WEBHOOK_SECRET=whsec_portone_...

# 공개값 (프론트엔드에서 포트원 SDK 초기화용)
# 포트원 콘솔 > 결제 연동 > 상점 아이디
NEXT_PUBLIC_PORTONE_STORE_ID=store-...

# 포트원 콘솔 > 결제 연동 > 채널 관리 > 토스페이먼츠 채널키
NEXT_PUBLIC_PORTONE_CHANNEL_KEY_TOSS=channel-key-...

# ──────────────────────────────────────────────────────────────
# 앱 URL
# ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-domain.com

# ──────────────────────────────────────────────────────────────
# Google Gemini AI (AI 리포트)
# Google AI Studio (aistudio.google.com) 에서 발급
# ──────────────────────────────────────────────────────────────
GOOGLE_GEMINI_API_KEY=AIza...

# ──────────────────────────────────────────────────────────────
# CRON 작업 인증 시크릿 (선택)
# Vercel Cron 또는 외부 스케줄러에서 호출 시 Bearer 토큰으로 사용
# ──────────────────────────────────────────────────────────────
CRON_SECRET=your-random-secret
